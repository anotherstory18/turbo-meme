<%- include('../partials/header') %>
<%- include('../partials/app-shell-start') %>
<form class="glass form-grid" method="post" action="/patients/register">
  <input name="fullName" placeholder="Full Name" required />
  <input name="age" type="number" placeholder="Age" required />
  <select name="gender"><option>Male</option><option>Female</option><option>Other</option></select>
  <input name="phone" placeholder="Phone Number" required />
  <input name="address" placeholder="Address" required />
  <input name="symptoms" placeholder="Symptoms" required />
  <select name="department"><% departments.forEach(d=>{ %><option><%= d %></option><% }) %></select>
  <select name="emergency"><option>No</option><option>Yes</option></select>
  <button class="btn primary" type="submit">Register + Generate OPD Slip</button>
</form>
<%- include('../partials/app-shell-end') %>
