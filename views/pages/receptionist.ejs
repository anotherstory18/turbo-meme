<%- include('../partials/header') %>
<%- include('../partials/app-shell-start') %>
<section class="quick-actions glass">
  <a class="btn primary" href="/patients/register">+ Register Patient</a>
  <a class="btn" href="/billing">Create Bill</a>
  <a class="btn" href="/receipts">Generate Receipt</a>
</section>
<section class="stats-grid">
